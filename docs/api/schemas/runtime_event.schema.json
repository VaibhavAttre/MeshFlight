    "SnapshotEmitted": {
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "minLength": 1,
          "title": "Event Id",
          "type": "string"
        },
        "run_id": {
          "minLength": 1,
          "title": "Run Id",
          "type": "string"
        },
        "emitted_at": {
          "minLength": 1,
          "title": "Emitted At",
          "type": "string"
        },
        "time_s": {
          "minimum": 0,
          "title": "Time S",
          "type": "number"
        },
        "event_type": {
