{
  "$defs": {
    "FailureInjected": {
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "minLength": 1,
          "title": "Event Id",
          "type": "string"
        },
        "run_id": {
          "minLength": 1,
          "title": "Run Id",
          "type": "string"
        },
        "emitted_at": {
          "minLength": 1,
          "title": "Emitted At",
          "type": "string"
        },
        "time_s": {
          "minimum": 0,
          "title": "Time S",
          "type": "number"
        },
        "event_type": {
          "const": "failure_injected",
          "default": "failure_injected",
          "title": "Event Type",
          "type": "string"
        },
        "failure_type": {
          "minLength": 1,
          "title": "Failure Type",
          "type": "string"
        },
        "target": {
          "minLength": 1,
          "title": "Target",
          "type": "string"
        },
        "start_time_s": {
          "minimum": 0,
          "title": "Start Time S",
          "type": "number"
        }
      },
      "required": [
        "event_id",
        "run_id",
        "emitted_at",
        "time_s",
        "failure_type",
        "target",
        "start_time_s"
      ],
      "title": "FailureInjected",
      "type": "object"
    },
    "FlowLifecycleEvent": {
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "minLength": 1,
          "title": "Event Id",
          "type": "string"
        },
        "run_id": {
          "minLength": 1,
          "title": "Run Id",
          "type": "string"
        },
        "emitted_at": {
          "minLength": 1,
          "title": "Emitted At",
          "type": "string"
        },
        "time_s": {
          "minimum": 0,
          "title": "Time S",
          "type": "number"
        },
        "event_type": {
          "enum": [
            "flow_started",
            "flow_ended"
          ],
          "title": "Event Type",
          "type": "string"
        },
        "flow_id": {
          "minLength": 1,
          "title": "Flow Id",
          "type": "string"
        },
        "flow_class": {
          "minLength": 1,
          "title": "Flow Class",
          "type": "string"
        },
        "src": {
          "minLength": 1,
          "title": "Src",
          "type": "string"
        },
        "dst": {
          "minLength": 1,
          "title": "Dst",
          "type": "string"
        },
        "rate_kbps": {
          "exclusiveMinimum": 0,
          "title": "Rate Kbps",
          "type": "integer"
        },
        "sla_latency_ms": {
          "exclusiveMinimum": 0,
          "title": "Sla Latency Ms",
          "type": "integer"
        }
      },
      "required": [
        "event_id",
        "run_id",
        "emitted_at",
        "time_s",
        "event_type",
        "flow_id",
        "flow_class",
        "src",
        "dst",
        "rate_kbps",
        "sla_latency_ms"
      ],
      "title": "FlowLifecycleEvent",
      "type": "object"
    },
    "FlowRerouted": {
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "minLength": 1,
          "title": "Event Id",
          "type": "string"
        },
        "run_id": {
          "minLength": 1,
          "title": "Run Id",
